# ──────────────────────────────────────────────────────────────
# Leo Dispatch — environment variables
# Copy this file to ".env.local" and fill in your real keys.
# The site runs without these (forms gracefully degrade), but the
# backend integrations below need them to go live.
# ──────────────────────────────────────────────────────────────

# Supabase (database, auth, document metadata storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email for applications + contact requests)
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=leodispatchinc@gmail.com

# UploadThing (document upload portal)
UPLOADTHING_TOKEN=

# Public site URL (used in emails / canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Admin dashboard auth (/admin) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                         # set a strong password
ADMIN_SESSION_SECRET=                   # long random string (signs the session cookie)

# ── "Forgot password" email via Gmail SMTP ──
ADMIN_NOTIFY_EMAIL=leodispatchinc@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=leodispatchinc@gmail.com
SMTP_PASS=                              # Gmail App Password (needs 2-Step Verification)
SMTP_FROM=Leo Dispatch Inc <leodispatchinc@gmail.com>
